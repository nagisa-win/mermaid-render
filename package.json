{
  "name": "mermaid-render",
  "version": "1.0.0",
  "description": "A web-based Mermaid diagram editor with real-time preview and image export",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "preact": "^10.25.0",
    "mermaid": "^11.13.0",
    "@monaco-editor/react": "^4.7.0",
    "html-to-image": "^1.11.13"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.1",
    "typescript": "^5.7.0",
    "vite": "^7.3.1",
    "terser": "^5.43.1",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "prettier": "^3.5.3",
    "@types/node": "^22.13.0",
    "globals": "^16.0.0",
    "typescript-eslint": "^8.26.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yanjunzhu/mermaid-render.git"
  },
  "keywords": [
    "mermaid",
    "diagram",
    "editor",
    "preact",
    "vite"
  ],
  "author": "",
  "license": "MIT"
}
